<Window x:Class="DotnetKumaUptimeDemo.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DotnetKumaUptimeDemo.Wpf.ViewModels"
        xmlns:conv="clr-namespace:DotnetKumaUptimeDemo.Wpf.Converters"
        mc:Ignorable="d"
        Title="DotnetKumaUptimeDemo Dashboard" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <conv:HealthStatusToBrushConverter x:Key="StatusBrush"/>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Overall Status Bar -->
        <Border Grid.Row="0" CornerRadius="8" Padding="12,8" Margin="0,0,0,12"
                Background="{Binding OverallStatus, Converter={StaticResource StatusBrush}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Overall Status:" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding OverallStatus}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Duration:" Foreground="White" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalDuration, StringFormat={}{0:F1}ms}" Foreground="White" VerticalAlignment="Center"/>
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="16,0,0,0"
                            Padding="12,4" Background="#33FFFFFF" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Error Message -->
        <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,0,0,8"
                   Visibility="{Binding ErrorMessage.Length, Converter={StaticResource BoolVis}}"/>

        <!-- Component Cards -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Checks}" Margin="0,0,0,12">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="8" Margin="4" Padding="12"
                            BorderThickness="2"
                            BorderBrush="{Binding Status, Converter={StaticResource StatusBrush}}">
                        <StackPanel>
                            <!-- Component Name -->
                            <TextBlock Text="{Binding Component}" FontSize="16" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <!-- Status Badge -->
                            <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Center" Margin="0,0,0,8"
                                    Background="{Binding Status, Converter={StaticResource StatusBrush}}">
                                <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="Bold"/>
                            </Border>
                            <!-- Description -->
                            <TextBlock Text="{Binding Description}" FontSize="11" TextWrapping="Wrap"
                                       Foreground="#64748b" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                            <!-- Data -->
                            <ItemsControl ItemsSource="{Binding Data}" FontSize="10" Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Foreground="#94a3b8">
                                            <Run Text="{Binding Key, Mode=OneWay}"/>:
                                            <Run Text="{Binding Value, Mode=OneWay}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Simulate Buttons -->
                            <UniformGrid Columns="2" Margin="0,4,0,0">
                                <Button Content="Simulate Failure" Margin="2" Padding="4"
                                        FontSize="10" Background="#ef4444" Foreground="White" BorderThickness="0"
                                        Command="{Binding DataContext.SimulateFailureCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Component}"/>
                                <Button Content="Recover" Margin="2" Padding="4"
                                        FontSize="10" Background="#22c55e" Foreground="White" BorderThickness="0"
                                        Command="{Binding DataContext.SimulateRecoveryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Component}"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Bottom Panel: Users + Service Info -->
        <UniformGrid Grid.Row="3" Columns="2" Rows="1">
            <Border CornerRadius="8" Margin="4" Padding="12" Background="#f8fafc" BorderThickness="1" BorderBrush="#e2e8f0">
                <StackPanel>
                    <TextBlock Text="Users" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding UsersText}" FontSize="11" Foreground="#475569"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="8" Margin="4" Padding="12" Background="#f8fafc" BorderThickness="1" BorderBrush="#e2e8f0">
                <StackPanel>
                    <TextBlock Text="Service Info" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding ServiceInfoText}" FontSize="11" Foreground="#475569"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</Window>
